# ============================================================
#  КУДА КЛАСТЬ: android/key.properties
#  Переименуй этот файл в key.properties и впиши свои данные.
#  НИКОГДА не добавляй key.properties и .keystore в git!
#  (они уже в .gitignore)
# ============================================================
#
#  ВАЖНО про storeFile:
#  - Для ЛОКАЛЬНОЙ сборки: положи .keystore в корень mystica-project
#    и используй путь ../../mystica-release.keystore
#  - Для GITHUB ACTIONS: keystore кладётся в android/app/, путь = mystica-release.keystore
#    (об этом заботится workflow автоматически — локальный key.properties для CI не нужен)

storePassword=ВВЕДИ_СВОЙ_ПАРОЛЬ
keyPassword=ВВЕДИ_СВОЙ_ПАРОЛЬ
keyAlias=mystica
storeFile=../../mystica-release.keystore
